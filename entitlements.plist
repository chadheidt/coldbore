<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hardened runtime entitlements for notarization.

  Apple requires the hardened runtime + notarization for distribution outside
  the App Store. These entitlements grant the minimum permissions Loadscope
  needs:

    - allow-jit                      → not needed for Loadscope (no JIT)
    - allow-unsigned-executable-memory → required because py2app's bundled
                                          Python interprets bytecode at runtime
    - allow-dyld-environment-variables → required because py2app sets
                                          DYLD_FRAMEWORK_PATH to find bundled libs
    - disable-library-validation       → required so the embedded PyQt5 dylibs
                                          (signed by Riverbank Computing or unsigned)
                                          can load alongside our own signature

  Network access (for the in-app update check + download) is allowed by default
  outside the App Store sandbox; no entitlement needed.

  When commercializing, revisit:
    - Add app-sandbox if going to App Store
    - Tighten library-validation if we ship our own re-signed PyQt5 build
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
